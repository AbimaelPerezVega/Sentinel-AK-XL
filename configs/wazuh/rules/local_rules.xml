<!-- Local rules -->

<group name="local,">

  <!-- Training Scenario Rules for Virtual SOC -->
  
  <!-- Rule for Malware Detection Training -->
  <rule id="100001" level="12">
    <if_sid>552</if_sid>
    <match>malware|virus|trojan|backdoor</match>
    <description>Training: Malware detection alert</description>
    <group>malware,training</group>
  </rule>

  <!-- Rule for Brute Force Attack Training -->
  <rule id="100002" level="10">
    <if_sid>5712</if_sid>
    <match>authentication failure</match>
    <same_source_ip />
    <frequency>5</frequency>
    <timeframe>300</timeframe>
    <description>Training: Multiple authentication failures from same source IP</description>
    <group>authentication_failed,brute_force,training</group>
  </rule>

  <!-- Rule for Suspicious File Access -->
  <rule id="100003" level="8">
    <category>ossec</category>
    <decoded_as>syscheck_new_entry</decoded_as>
    <match>/etc/passwd|/etc/shadow|/etc/hosts</match>
    <description>Training: Sensitive file modification detected</description>
    <group>syscheck,file_monitoring,training</group>
  </rule>

  <!-- Rule for Lateral Movement Detection -->
  <rule id="100004" level="9">
    <if_sid>5401</if_sid>
    <match>net use|psexec|wmic</match>
    <description>Training: Potential lateral movement command detected</description>
    <group>lateral_movement,training</group>
  </rule>

  <!-- Rule for Data Exfiltration Attempt -->
  <rule id="100005" level="11">
    <if_sid>1002</if_sid>
    <match>scp|rsync|curl.*-o|wget.*-O</match>
    <description>Training: Potential data exfiltration command detected</description>
    <group>data_exfiltration,training</group>
  </rule>

  <!-- Rule for Privilege Escalation -->
  <rule id="100006" level="10">
    <if_sid>5401</if_sid>
    <match>sudo|su -|chmod.*777|chown.*root</match>
    <description>Training: Privilege escalation attempt detected</description>
    <group>privilege_escalation,training</group>
  </rule>

  <!-- Rule for Suspicious Network Activity -->
  <rule id="100007" level="8">
    <if_sid>1002</if_sid>
    <match>nmap|ncat|netcat|nc -</match>
    <description>Training: Suspicious network reconnaissance tool detected</description>
    <group>network_scan,training</group>
  </rule>

  <!-- Rule for Web Attack Detection -->
  <rule id="100008" level="9">
    <if_sid>31100</if_sid>
    <match>../|&lt;script|SELECT.*FROM|UNION.*SELECT</match>
    <description>Training: Web application attack attempt detected</description>
    <group>web_attack,training</group>
  </rule>

</group>
